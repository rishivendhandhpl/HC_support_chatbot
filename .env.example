# ======================================================================
# H&C AI Stylist — environment configuration
# Copy to .env and fill in. NEVER commit a real .env.
# ======================================================================

# --- OpenAI (required) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Storage backend ---
# "memory" = file-backed dev store (no DB). "pgvector" = Postgres (production).
STORE_BACKEND=pgvector

# --- Database (used when STORE_BACKEND=pgvector) ---
DATABASE_URL=postgresql://hc:hc@db:5432/hc_chatbot
POSTGRES_USER=hc
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=hc_chatbot

# --- Security ---
ALLOWED_ORIGINS=https://www.haircompounds.com
RATE_LIMIT_PER_MIN=20

# Shopify App Proxy verification (PRODUCTION: set true + the app secret).
# When true, /chat requires a Shopify-signed request and derives Pro status
# from the verified logged_in_customer_id — the client cannot forge is_pro.
REQUIRE_PROXY_SIGNATURE=true
SHOPIFY_APP_SECRET=shpss_your_app_client_secret

# --- Widget build-time ---
# In production this is the App Proxy subpath (same-origin), e.g. /apps/hc-chat
VITE_API_URL=/apps/hc-chat
